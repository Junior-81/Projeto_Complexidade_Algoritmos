# Conexao com o PostgreSQL (mesmo valor usado no docker-compose.yml)
DATABASE_URL=postgresql+psycopg://rotas:rotas@localhost:5433/rotas_recife

# Diretorio onde estao os CSVs e o feed GTFS (note o aninhamento data/data)
DATA_DIR=data/data

# Tempo maximo (segundos) permitido para o calculo de uma rota
GRAPH_TIMEOUT_SECONDS=10
